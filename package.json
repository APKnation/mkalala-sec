{
  "name": "school-management-tailwind",
  "version": "1.0.0",
  "description": "Tailwind CSS for School Management System",
  "main": "index.js",
  "scripts": {
    "build-css": "tailwindcss -i ./static/src/input.css -o ./static/css/tailwind.css --watch",
    "build-css-prod": "tailwindcss -i ./static/src/input.css -o ./static/css/tailwind.css --minify"
  },
  "keywords": ["tailwind", "css", "django", "school-management"],
  "author": "School Management Team",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "tailwindcss-animate": "^1.0.7"
  }
}
