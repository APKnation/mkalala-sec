# Environment variables for School Management System
# Copy this file to .env and update with your values

# Django Settings
SECRET_KEY=django-insecure-icspmxc%%)0_zh$(mka!+8ot$z#(*^pvd5m!5$k@-_ot&v4%j8
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=school_management
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# SQLite (for development)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/1

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@mkalala.ac.tz

# AWS S3 Configuration (optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Twilio Configuration (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe Configuration (for payments)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Sentry Configuration (for error tracking)
SENTRY_DSN=your-sentry-dsn

# Google OAuth (optional)
GOOGLE_OAUTH2_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth (optional)
MICROSOFT_OAUTH2_CLIENT_ID=your-microsoft-client-id
MICROSOFT_OAUTH2_CLIENT_SECRET=your-microsoft-client-secret

# Security Settings
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Session Configuration
SESSION_ENGINE=django.contrib.sessions.backends.cache
SESSION_CACHE_ALIAS=default

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=debug.log

# Media Files
MEDIA_URL=/media/
MEDIA_ROOT=media/

# Static Files
STATIC_URL=/static/
STATIC_ROOT=staticfiles/

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Channels (WebSocket)
CHANNEL_LAYERS=redis.core.channel.RedisChannelLayer

# Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXX-X

# Feature Flags
ENABLE_EMAIL_VERIFICATION=True
ENABLE_SMS_NOTIFICATIONS=False
ENABLE_PAYMENT_SYSTEM=False
ENABLE_VIDEO_CONFERENCING=False
ENABLE_AI_FEATURES=False

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=local

# Performance
ENABLE_CACHE=True
CACHE_TIMEOUT=300
ENABLE_COMPRESSION=True

# Development Settings
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILING=False

# API Configuration
API_RATE_LIMIT=1000/hour
API_TIMEOUT=30

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png,.gif

# Security Headers
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# CORS Settings (for API)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Social Authentication
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-oauth-key
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-oauth-secret

# Monitoring
ENABLE_HEALTH_CHECK=True
HEARTBEAT_INTERVAL=30

# Email Templates
EMAIL_TEMPLATE_DIR=templates/email/

# Custom Settings
SCHOOL_NAME=Mkalala Secondary School
SCHOOL_ADDRESS=123 Education Street, Learning City, LC 12345
SCHOOL_PHONE=+1 (555) 123-4567
SCHOOL_EMAIL=info@mkalala.ac.tz

# Academic Settings
DEFAULT_ACADEMIC_YEAR=2024-2025
SEMESTER_START_DATE=2024-01-15
SEMESTER_END_DATE=2024-05-15

# Grade Settings
DEFAULT_GPA_SCALE=4.0
PASSING_GRADE=D
HONORS_GPA=3.5

# Attendance Settings
ATTENDANCE_THRESHOLD=75
LATE_GRACE_PERIOD=15

# Fee Settings
LATE_FEE_RATE=0.02
PAYMENT_REMINDER_DAYS=7

# Notification Settings
NOTIFICATION_RETENTION_DAYS=90
EMAIL_NOTIFICATION_BATCH_SIZE=50

# Report Settings
REPORT_GENERATION_TIMEOUT=300
MAX_REPORT_SIZE=104857600  # 100MB
